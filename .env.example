# OpenCode Proxy configuration
# Copy this file to .env and fill in your values

# Port the proxy server will listen on (default: 8080)
PROXY_PORT=8080

# OpenCode Zen API base URL
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# Your OpenCode API key (required)
OPENCODE_GO_API_KEY=your_api_key_here

# Session cache TTL in milliseconds (default: 1800000 = 30 min)
SESSION_TTL_MS=1800000

# Max JSON body size in MB (default: 200)
OPENCODE_PROXY_JSON_LIMIT_MB=200

# Backend timeout in milliseconds (default: 90000 = 90s)
OPENCODE_BACKEND_TIMEOUT_MS=90000
